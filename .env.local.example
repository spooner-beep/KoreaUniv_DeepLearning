# Windows 로컬 PC용 (.env 로 복사)
FASHION_PROFILE=local
FASHION_REPO_ROOT=C:\Fashion Cycle
FASHION_DATA_ROOT=C:\Fashion Cycle\Data
FASHION_IMAGE_DIR=C:\Fashion Cycle\ku_deep_learning_project\data_resized

# GPU 학습 (NVIDIA + CUDA PyTorch cu128 nightly). GPU 없으면 FASHION_DEVICE 줄 삭제
# 발열/부하 완화 기본값: batch/worker/thread/memory 상한을 낮춤
FASHION_DEVICE=cuda
FASHION_NUM_WORKERS=2
FASHION_CUSTOM_NUM_WORKERS=1
FASHION_BATCH_SIZE=48
FASHION_PIN_MEMORY=1
FASHION_PREFETCH_FACTOR=1
FASHION_TORCH_NUM_THREADS=4
FASHION_TORCH_NUM_INTEROP_THREADS=1
FASHION_CUDA_MEMORY_FRACTION=0.90
FASHION_CUDNN_BENCHMARK=0

# 그래프 창 표시 (evaluate 시)
FASHION_SHOW_PLOTS=1

# 한글 폰트
FASHION_FONT_MATPLOTLIB=Malgun Gothic
